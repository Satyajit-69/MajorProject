<% layout('/layouts/boilerplate') -%>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Mono:wght@400;500&display=swap');

  .auth-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f0e8;
    padding: 20px;
  }

  .auth-card {
    display: flex;
    width: 100%;
    max-width: 960px;
    min-height: 620px;
    border: 3px solid #000;
    box-shadow: 10px 10px 0px #d90429;
    background: #fff;
    overflow: hidden;
  }

  /* ── LEFT ILLUSTRATION PANEL ── */
  .auth-left {
    flex: 1;
    background: #d90429;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 30px;
    position: relative;
    overflow: hidden;
    border-right: 3px solid #000;
  }

  .auth-left::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, rgba(0,0,0,0.08) 0px, rgba(0,0,0,0.08) 1px, transparent 1px, transparent 40px),
      repeating-linear-gradient(90deg, rgba(0,0,0,0.08) 0px, rgba(0,0,0,0.08) 1px, transparent 1px, transparent 40px);
    pointer-events: none;
  }

  .auth-left svg {
    width: 260px;
    max-width: 90%;
    z-index: 1;
    filter: drop-shadow(4px 4px 0px rgba(0,0,0,0.3));
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-12px); }
  }

  .left-tagline {
    z-index: 1;
    margin-top: 28px;
    text-align: center;
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 1.5rem;
    color: #fff;
    line-height: 1.3;
    letter-spacing: 1px;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.2);
  }

  .left-tagline span {
    display: block;
    font-size: 0.85rem;
    font-family: 'DM Mono', monospace;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-top: 8px;
    opacity: 0.85;
  }

  .dot-row { display: flex; gap: 8px; margin-top: 24px; z-index: 1; }
  .dot-row .dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    border: 2px solid rgba(255,255,255,0.7);
  }
  .dot-row .dot.active { background: #fff; }

  /* perks list */
  .perks {
    z-index: 1;
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    max-width: 240px;
  }

  .perk-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.9);
  }

  .perk-icon {
    width: 26px; height: 26px;
    background: rgba(255,255,255,0.2);
    border: 1.5px solid rgba(255,255,255,0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
  }

  /* ── RIGHT FORM PANEL ── */
  .auth-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px 44px;
    background: #fff;
  }

  .form-heading {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 2.6rem;
    color: #000;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1;
    margin-bottom: 6px;
  }

  .form-subhead {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 32px;
  }

  .form-label-custom {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #000;
    margin-bottom: 6px;
    display: block;
  }

  .input-wrap {
    position: relative;
    margin-bottom: 20px;
  }

  .input-custom {
    width: 100%;
    border: 2px solid #000;
    border-radius: 0;
    padding: 12px 14px 12px 42px;
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    background: #f5f0e8;
    outline: none;
    transition: box-shadow 0.2s, background 0.2s;
    display: block;
    box-sizing: border-box;
  }

  .input-custom:focus {
    background: #fff;
    box-shadow: 4px 4px 0px #d90429;
  }

  .input-icon {
    position: absolute;
    left: 13px;
    top: 50%;
    transform: translateY(-50%);
    color: #aaa;
    pointer-events: none;
    transition: color 0.2s;
  }

  .input-wrap:focus-within .input-icon { color: #d90429; }

  /* password strength bar */
  .strength-bar-wrap {
    margin-top: -14px;
    margin-bottom: 20px;
    display: flex;
    gap: 4px;
  }

  .strength-seg {
    flex: 1;
    height: 3px;
    background: #e0d8cc;
    border-radius: 2px;
    transition: background 0.3s;
  }

  .strength-seg.weak   { background: #d90429; }
  .strength-seg.medium { background: #f4a800; }
  .strength-seg.strong { background: #2a9d5c; }

  .btn-signup {
    width: 100%;
    background: #d90429;
    color: #fff;
    border: 2px solid #000;
    border-radius: 0;
    font-family: 'DM Mono', monospace;
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 14px;
    cursor: pointer;
    transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
    margin-top: 4px;
  }

  .btn-signup:hover {
    background: #000;
    border-color: #000;
    box-shadow: 4px 4px 0px #d90429;
    transform: translate(-2px, -2px);
  }

  .btn-signup:active { transform: translate(0,0); box-shadow: none; }

  .login-link {
    text-align: center;
    margin-top: 24px;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 1px;
    color: #888;
  }

  .login-link a {
    color: #000;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 2px solid #d90429;
    padding-bottom: 1px;
    transition: color 0.2s;
  }

  .login-link a:hover { color: #d90429; }

  @media (max-width: 700px) {
    .auth-left { display: none; }
    .auth-right { padding: 40px 28px; }
    .auth-card { box-shadow: 6px 6px 0px #d90429; }
  }
</style>

<div class="auth-wrapper">
  <div class="auth-card">

    <!-- LEFT: Illustration -->
    <div class="auth-left">

      <!-- SVG: person with key / unlock -->
      <svg viewBox="0 0 220 210" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- desk -->
        <rect x="20" y="155" width="180" height="8" rx="2" fill="#000"/>
        <rect x="30" y="163" width="12" height="28" rx="2" fill="#000"/>
        <rect x="178" y="163" width="12" height="28" rx="2" fill="#000"/>

        <!-- open notebook -->
        <rect x="52" y="120" width="116" height="36" rx="3" fill="#fff" stroke="#000" stroke-width="2.5"/>
        <line x1="110" y1="120" x2="110" y2="156" stroke="#000" stroke-width="1.5"/>
        <rect x="60" y="128" width="42" height="4" rx="2" fill="#ddd"/>
        <rect x="60" y="136" width="36" height="4" rx="2" fill="#ddd"/>
        <rect x="60" y="144" width="28" height="4" rx="2" fill="#ddd"/>
        <rect x="118" y="128" width="42" height="4" rx="2" fill="#d90429" opacity="0.5"/>
        <rect x="118" y="136" width="36" height="4" rx="2" fill="#ddd"/>
        <rect x="118" y="144" width="42" height="4" rx="2" fill="#ddd"/>

        <!-- person body -->
        <rect x="88" y="46" width="44" height="32" rx="6" fill="#fff" stroke="#000" stroke-width="3"/>
        <!-- head -->
        <circle cx="110" cy="34" r="16" fill="#fff" stroke="#000" stroke-width="3"/>
        <!-- eyes — excited/happy -->
        <path d="M104 31 Q106 28 108 31" stroke="#000" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M112 31 Q114 28 116 31" stroke="#000" stroke-width="2" fill="none" stroke-linecap="round"/>
        <!-- big smile -->
        <path d="M103 38 Q110 45 117 38" stroke="#000" stroke-width="2" stroke-linecap="round" fill="none"/>
        <!-- hair -->
        <path d="M94 26 Q110 15 126 26" stroke="#000" stroke-width="3" stroke-linecap="round" fill="none"/>

        <!-- arms up/waving -->
        <line x1="88" y1="54" x2="68" y2="38" stroke="#000" stroke-width="3" stroke-linecap="round"/>
        <line x1="132" y1="54" x2="152" y2="38" stroke="#000" stroke-width="3" stroke-linecap="round"/>

        <!-- floating key -->
        <circle cx="58" cy="24" r="10" fill="rgba(255,255,255,0.9)" stroke="#fff" stroke-width="2"/>
        <circle cx="58" cy="24" r="5" fill="none" stroke="#000" stroke-width="2.5"/>
        <rect x="64" y="22" width="14" height="4" rx="1" fill="#000"/>
        <rect x="72" y="26" width="4" height="5" rx="1" fill="#000"/>

        <!-- sparkles -->
        <text x="150" y="22" font-size="18" fill="rgba(255,255,255,0.7)">✦</text>
        <text x="16" y="48" font-size="13" fill="rgba(255,255,255,0.5)">★</text>
        <text x="168" y="60" font-size="10" fill="rgba(255,255,255,0.4)">◆</text>
        <text x="30" y="100" font-size="12" fill="rgba(255,255,255,0.35)">✦</text>
      </svg>

      <div class="left-tagline">
        Join the club!
        <span>Find your next stay</span>
      </div>

      <div class="perks">
        <div class="perk-item"><div class="perk-icon">🌍</div> Discover listings worldwide</div>
        <div class="perk-item"><div class="perk-icon">⚡</div> Book in under a minute</div>
        <div class="perk-item"><div class="perk-icon">🔒</div> Safe & secure stays</div>
      </div>

      <div class="dot-row" style="margin-top: 20px;">
        <div class="dot active"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
    </div>

    <!-- RIGHT: Form -->
    <div class="auth-right">
      <div class="form-heading">Sign Up</div>
      <div class="form-subhead">Create your free account</div>

      <form action="/signup" method="POST" class="needs-validation" novalidate>

        <label class="form-label-custom" for="username">Username</label>
        <div class="input-wrap">
          <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <input id="username" name="username" type="text" class="input-custom" placeholder="your_username" required>
        </div>

        <label class="form-label-custom" for="email">Email</label>
        <div class="input-wrap">
          <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <input id="email" name="email" type="email" class="input-custom" placeholder="you@example.com" required>
        </div>

        <label class="form-label-custom" for="password">Password</label>
        <div class="input-wrap" style="margin-bottom: 6px;">
          <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <input id="password" name="password" type="password" class="input-custom" placeholder="min. 6 characters" required minlength="6" oninput="checkStrength(this.value)">
        </div>

        <!-- password strength bar -->
        <div class="strength-bar-wrap">
          <div class="strength-seg" id="seg1"></div>
          <div class="strength-seg" id="seg2"></div>
          <div class="strength-seg" id="seg3"></div>
          <div class="strength-seg" id="seg4"></div>
        </div>

        <button type="submit" class="btn-signup">Create Account →</button>

        <div class="login-link">
          Already have an account? <a href="/login">Log in</a>
        </div>
      </form>
    </div>

  </div>
</div>

<script>
(function () {
  'use strict';
  document.querySelectorAll('.needs-validation').forEach(function (form) {
    form.addEventListener('submit', function (e) {
      if (!form.checkValidity()) { e.preventDefault(); e.stopPropagation(); }
      form.classList.add('was-validated');
    });
  });
})();

function checkStrength(val) {
  const segs = [
    document.getElementById('seg1'),
    document.getElementById('seg2'),
    document.getElementById('seg3'),
    document.getElementById('seg4'),
  ];
  // reset
  segs.forEach(s => { s.className = 'strength-seg'; });
  if (!val) return;

  let score = 0;
  if (val.length >= 6)  score++;
  if (val.length >= 10) score++;
  if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;

  const cls = score <= 1 ? 'weak' : score <= 2 ? 'medium' : 'strong';
  for (let i = 0; i < score; i++) segs[i].classList.add(cls);
}
</script>
